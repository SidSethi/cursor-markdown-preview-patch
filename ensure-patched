#!/usr/bin/env bash
#
# Ensure Cursor's editable rendered Markdown preview patch is present.
#
# Intended for launchd or other update triggers. It exits quickly when the
# managed patch is already installed, and runs ./patch only when needed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR

# shellcheck source=lib/cursor-patch-common.sh
source "$SCRIPT_DIR/lib/cursor-patch-common.sh"

readonly PATCH_CMD="${CURSOR_MARKDOWN_PREVIEW_PATCH_CMD:-$SCRIPT_DIR/patch}"
readonly LOCK_DIR="${CURSOR_MARKDOWN_PREVIEW_PATCH_LOCK_DIR:-${TMPDIR:-/tmp}/cursor-markdown-preview-patch.ensure.lock}"
readonly DEBOUNCE_SECONDS="${CURSOR_MARKDOWN_PREVIEW_PATCH_DEBOUNCE_SECONDS:-20}"

print_script_usage() {
  cat <<'USAGE' >&2
Usage: ensure-patched [patch args...]

Checks whether Cursor's workbench already contains this repo's managed CSS/JS
patch. If not, runs ./patch with any provided arguments. Designed for launchd
WatchPaths triggers after Cursor updates replace the app bundle.

Environment:
  CURSOR_WORKBENCH_HTML
    Test hook or explicit workbench.html path.
  CURSOR_MARKDOWN_PREVIEW_PATCH_CMD
    Patch command to run. Defaults to this repo's ./patch.
  CURSOR_MARKDOWN_PREVIEW_PATCH_LOCK_DIR
    Lock directory. Defaults to TMPDIR/cursor-markdown-preview-patch.ensure.lock.
  CURSOR_MARKDOWN_PREVIEW_PATCH_DEBOUNCE_SECONDS
    Seconds to wait before checking. Defaults to 20.
  CURSOR_APP_BUNDLE
    Primary Cursor.app bundle. Defaults to /Applications/Cursor.app.
  CURSOR_HOME_APP_BUNDLE
    Secondary Cursor.app bundle. Defaults to ~/Applications/Cursor.app.
  CURSOR_SHIPIT_DIR
    Cursor ShipIt cache directory. Defaults to ~/Library/Caches/<bundle id>.ShipIt.
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

main() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_script_usage
    exit 0
  fi

  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    echo "OK: another ensure-patched run is already active."
    exit 0
  fi
  trap 'rmdir "$LOCK_DIR" 2>/dev/null || true' EXIT

  echo "Waiting ${DEBOUNCE_SECONDS}s for Cursor update files to settle..."
  sleep "$DEBOUNCE_SECONDS"

  local workbench_html
  local workbench_targets=()
  while IFS= read -r workbench_html; do
    workbench_targets+=("$workbench_html")
  done < <(cursor_patch_find_workbench_htmls)

  if [[ "${#workbench_targets[@]}" -eq 0 ]]; then
    die "Cursor workbench.html not found in known locations"
  fi

  local missing_targets=()
  for workbench_html in "${workbench_targets[@]}"; do
    if cursor_patch_is_present "$workbench_html"; then
      echo "OK: patch already present in $workbench_html"
    else
      missing_targets+=("$workbench_html")
    fi
  done

  if [[ "${#missing_targets[@]}" -eq 0 ]]; then
    echo "OK: Cursor Markdown preview patch already present."
    exit 0
  fi

  [[ -x "$PATCH_CMD" ]] || die "patch command not found or not executable: $PATCH_CMD"

  local failed=0
  for workbench_html in "${missing_targets[@]}"; do
    echo "Applying Cursor Markdown preview patch to $workbench_html..."
    if ! CURSOR_WORKBENCH_HTML="$workbench_html" "$PATCH_CMD" "$@"; then
      echo "WARN: failed to patch $workbench_html" >&2
      failed=1
      continue
    fi

    if cursor_patch_is_present "$workbench_html"; then
      echo "OK: Cursor Markdown preview patch ensured in $workbench_html."
    else
      echo "WARN: patch command completed, but managed markers were not found in $workbench_html" >&2
      failed=1
    fi
  done

  if [[ "$failed" -ne 0 ]]; then
    die "one or more Cursor workbench targets could not be patched"
  fi
}

main "$@"
