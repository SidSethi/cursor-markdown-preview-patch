#!/usr/bin/env bash
#
# Patch script to apply custom CSS/JS to Cursor's editable rendered Markdown preview
#
# Works by injecting Cursor.app's workbench.html with a managed block

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly CSS_TEMPLATE="$SCRIPT_DIR/custom.css"
readonly JS_TEMPLATE="$SCRIPT_DIR/custom.js"
readonly JS_OUTPUT_NAME="cursor-markdown-preview-patch.js"
readonly CURSOR_SETTINGS="$HOME/Library/Application Support/Cursor/User/settings.json"
readonly BACKUP_ROOT="${CURSOR_WORKBENCH_PATCH_BACKUP_ROOT:-$HOME/Library/Application Support/Cursor/workbench-patch-backups}"
readonly DEFAULT_EDITOR_FONT_SIZE="13"
readonly CSS_FONT_SIZE_PROPERTY="--cursor-inline-markdown-editor-font-size"
readonly JS_VERIFY_TOKEN="cursorMarkdownPreviewFrontmatter"

readonly START_MARKER="<!-- !! VSCODE-CUSTOM-CSS-START !! -->"
readonly END_MARKER="<!-- !! VSCODE-CUSTOM-CSS-END !! -->"
readonly SESSION_MARKER_PREFIX="<!-- !! VSCODE-CUSTOM-CSS-SESSION-ID"

PATCH_TMP_DIR=""

# Print the script's command-line help text.
print_script_usage() {
  cat <<'USAGE' >&2
Usage: patch [--font-size editor|css|NUMBER]

Patches Cursor.app's workbench.html with custom.css and installs custom.js as a
same-origin workbench asset. Re-run after Cursor updates overwrite the app
bundle.

Options:
  --font-size editor
    Read Cursor's editor.fontSize setting and inject that px value. This is the
    default.
  --font-size css
    Use the font-size variable exactly as written in custom.css.
  --font-size NUMBER
    Inject NUMBER as px, for example --font-size 18.

Environment:
  CURSOR_WORKBENCH_PATCH_BACKUP_ROOT
    Directory where timestamped workbench backups are written.
USAGE
}

# Print an error message and stop immediately with failure.
die() {
  echo "error: $*" >&2
  exit 1
}

# Return success when the input is an integer or decimal number.
is_number() {
  [[ "${1:-}" =~ ^[0-9]+([.][0-9]+)?$ ]]
}

# Parse command-line options and print the selected font-size mode.
parse_font_size_mode() {
  local mode="editor"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --font-size)
        [[ $# -ge 2 ]] || die "--font-size requires editor, css, or NUMBER"
        mode="$2"
        shift 2
        ;;
      -h|--help)
        print_script_usage
        exit 0
        ;;
      *)
        print_script_usage
        exit 2
        ;;
    esac
  done

  if [[ "$mode" == "editor" || "$mode" == "css" ]] || is_number "$mode"; then
    printf '%s\n' "$mode"
  else
    die "invalid --font-size value: $mode"
  fi
}

# Locate Cursor's workbench.html, with an envvar override for tests.
find_workbench_html() {
  local path

  # Test hook: patch this file instead of the real Cursor.app bundle.
  if [[ -n "${CURSOR_WORKBENCH_HTML:-}" ]]; then
    [[ -f "$CURSOR_WORKBENCH_HTML" ]] || return 1
    printf '%s\n' "$CURSOR_WORKBENCH_HTML"
    return 0
  fi

  local candidates=(
    "/Applications/Cursor.app/Contents/Resources/app/out/vs/code/electron-sandbox/workbench/workbench.html"
    "$HOME/Applications/Cursor.app/Contents/Resources/app/out/vs/code/electron-sandbox/workbench/workbench.html"
    "/Applications/Cursor.app/Contents/Resources/app/out/vs/code/electron-browser/workbench/workbench.html"
    "$HOME/Applications/Cursor.app/Contents/Resources/app/out/vs/code/electron-browser/workbench/workbench.html"
  )

  for path in "${candidates[@]}"; do
    if [[ -f "$path" ]]; then
      printf '%s\n' "$path"
      return 0
    fi
  done

  return 1
}

# Read Cursor's editor.fontSize setting, falling back to DEFAULT_EDITOR_FONT_SIZE.
read_editor_font_size() {
  local value

  if [[ ! -f "$CURSOR_SETTINGS" ]]; then
    printf '%s\n' "$DEFAULT_EDITOR_FONT_SIZE"
    return
  fi

  if command -v jq >/dev/null 2>&1; then
    value=$(jq -r '."editor.fontSize" // empty' "$CURSOR_SETTINGS" 2>/dev/null || true)
    if is_number "$value"; then
      printf '%s\n' "$value"
      return
    fi
  fi

  value=$(
    sed -nE 's/^[[:space:]]*"editor\.fontSize"[[:space:]]*:[[:space:]]*([0-9]+([.][0-9]+)?).*/\1/p' "$CURSOR_SETTINGS" |
      head -n 1
  )

  if is_number "$value"; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$DEFAULT_EDITOR_FONT_SIZE"
  fi
}

# Render the source CSS to stdout, optionally substituting the font-size
# variable without modifying custom.css itself.
render_css() {
  local font_size_px="$1"

  [[ -f "$CSS_TEMPLATE" ]] || die "CSS file not found: $CSS_TEMPLATE"

  if [[ "$font_size_px" == "css" ]]; then
    cat "$CSS_TEMPLATE"
    return
  fi

  PATCH_FONT_SIZE_PX="$font_size_px" \
    PATCH_CSS_FONT_SIZE_PROPERTY="$CSS_FONT_SIZE_PROPERTY" \
    perl -pe '
      BEGIN {
        $property = quotemeta($ENV{"PATCH_CSS_FONT_SIZE_PROPERTY"});
        $font_size = $ENV{"PATCH_FONT_SIZE_PX"};
      }
      s/^(\s*$property\s*:\s*)[^;]+(;.*)$/${1}${font_size}${2}/;
    ' "$CSS_TEMPLATE"
}

# Strip any previously injected managed block so reruns stay idempotent.
remove_existing_patch() {
  local source_html="$1"
  local cleaned_html="$2"

  perl -0pe '
    s/\n?<!-- !! VSCODE-CUSTOM-CSS-START !! -->.*?<!-- !! VSCODE-CUSTOM-CSS-END !! -->\n?/\n/gs;
    s/\n?<!-- !! VSCODE-CUSTOM-CSS-SESSION-ID:?\s*[^>]* -->\n?/\n/g;
  ' "$source_html" > "$cleaned_html"
}

# Build the HTML block that will be injected into workbench.html.
build_injection_block() {
  local session_id="$1"
  local rendered_css="$2"
  local block_html="$3"

  {
    printf '%s %s !! -->\n' "$SESSION_MARKER_PREFIX" "$session_id"
    printf '%s\n' "$START_MARKER"
    printf '<style>\n'
    cat "$rendered_css"
    printf '\n</style>\n'
    printf '<script src="./%s?v=%s"></script>\n' "$JS_OUTPUT_NAME" "$session_id"
    printf '%s\n' "$END_MARKER"
  } > "$block_html"
}

# Insert the generated block immediately before workbench.html's closing tag.
insert_block_before_closing_html() {
  local cleaned_html="$1"
  local block_html="$2"
  local patched_html="$3"

  awk -v block_file="$block_html" '
    /<\/html>/ && inserted == 0 {
      while ((getline line < block_file) > 0) {
        print line
      }
      close(block_file)
      inserted = 1
    }
    { print }
    END {
      if (inserted != 1) {
        exit 2
      }
    }
  ' "$cleaned_html" > "$patched_html"
}

# Confirm the patched workbench contains the expected managed markers and assets.
verify_patch() {
  local workbench_html="$1"
  local managed_js="$2"

  grep -qF "$START_MARKER" "$workbench_html" &&
    grep -qF "$END_MARKER" "$workbench_html" &&
    grep -qF -- "$CSS_FONT_SIZE_PROPERTY" "$workbench_html" &&
    grep -qF -- "$JS_OUTPUT_NAME" "$workbench_html" &&
    [[ -f "$managed_js" ]] &&
    grep -qF -- "$JS_VERIFY_TOKEN" "$managed_js"
}

# Print a unique backup directory path for this patch run.
create_backup_dir() {
  local session_id="$1"
  local backup_dir="$BACKUP_ROOT/cursor-app-$session_id"
  local suffix=1

  mkdir -p "$BACKUP_ROOT"

  while ! mkdir "$backup_dir" 2>/dev/null; do
    backup_dir="$BACKUP_ROOT/cursor-app-$session_id-$suffix"
    suffix=$((suffix + 1))
  done

  printf '%s\n' "$backup_dir"
}

main() {
  local font_size_mode
  font_size_mode="$(parse_font_size_mode "$@")"

  local workbench_html
  workbench_html=$(find_workbench_html) ||
    die "Cursor workbench.html not found in known locations"
  [[ -f "$JS_TEMPLATE" ]] || die "JS file not found: $JS_TEMPLATE"

  local font_size_label font_size_px session_id
  if [[ "$font_size_mode" == "editor" ]]; then
    font_size_px="$(read_editor_font_size)px"
    font_size_label="editor.fontSize -> $font_size_px"
  elif [[ "$font_size_mode" == "css" ]]; then
    font_size_px="css"
    font_size_label="custom.css"
  else
    font_size_px="${font_size_mode}px"
    font_size_label="--font-size -> $font_size_px"
  fi
  session_id="$(date '+%Y%m%d-%H%M%S')"

  local backup_dir backup_path
  backup_dir="$(create_backup_dir "$session_id")"
  backup_path="$backup_dir/workbench.html"

  local tmp_dir
  # mktemp -d creates a new empty temporary directory and prints its path.
  tmp_dir="$(mktemp -d)"
  PATCH_TMP_DIR="$tmp_dir"
  # Every run gets a fresh temp directory. It holds the rendered CSS and patched
  # workbench candidate, then is deleted automatically when the script exits.
  # trap registers cleanup code that runs when the script exits for any reason.
  trap '[[ -n "${PATCH_TMP_DIR:-}" ]] && rm -rf "$PATCH_TMP_DIR"' EXIT

  local cleaned_html rendered_css block_html patched_html
  cleaned_html="$tmp_dir/workbench.cleaned.html"
  rendered_css="$tmp_dir/custom.css"
  block_html="$tmp_dir/custom-css-block.html"
  patched_html="$tmp_dir/workbench.patched.html"

  cp -p "$workbench_html" "$backup_path"

  render_css "$font_size_px" > "$rendered_css"
  remove_existing_patch "$workbench_html" "$cleaned_html"
  build_injection_block "$session_id" "$rendered_css" "$block_html"

  insert_block_before_closing_html "$cleaned_html" "$block_html" "$patched_html" || {
    echo "backup retained at: $backup_path" >&2
    die "</html> not found in $workbench_html"
  }

  local managed_js
  managed_js="$(dirname "$workbench_html")/$JS_OUTPUT_NAME"

  if ! cp "$JS_TEMPLATE" "$managed_js"; then
    echo "backup retained at: $backup_path" >&2
    die "failed to write managed Cursor preview JS asset; grant App Management permission to the app running this script, or run it from a terminal that already has that permission"
  fi

  if ! cp "$patched_html" "$workbench_html"; then
    echo "backup retained at: $backup_path" >&2
    die "failed to write Cursor workbench.html; grant App Management permission to the app running this script, or run it from a terminal that already has that permission"
  fi

  if ! verify_patch "$workbench_html" "$managed_js"; then
    cp -p "$backup_path" "$workbench_html"
    die "marker verification failed; restored backup"
  fi

  cat <<EOF
OK: Cursor workbench CSS/JS injection applied.

Workbench:
  $workbench_html

Rendered CSS:
  font size -> $font_size_label
  source -> $CSS_TEMPLATE

Rendered JS:
  source -> $JS_TEMPLATE
  installed -> $managed_js

Backup:
  $backup_path

Next:
  Run "Developer: Reload Window" in Cursor, or restart Cursor.

Rollback:
  ./rollback
  # or restore this exact backup:
  ./rollback '$backup_path'
EOF
}

main "$@"
