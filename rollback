#!/usr/bin/env bash
#
# Rollback script to restore Cursor.app's workbench.html from a patch backup.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR

# shellcheck source=lib/cursor-patch-common.sh
source "$SCRIPT_DIR/lib/cursor-patch-common.sh"

readonly BACKUP_ROOT="${CURSOR_WORKBENCH_PATCH_BACKUP_ROOT:-$HOME/Library/Application Support/Cursor/workbench-patch-backups}"

# Print the script's command-line help text.
print_script_usage() {
  cat <<'USAGE' >&2
Usage: rollback [backup-workbench.html]

Restores Cursor.app's workbench.html from a patch backup. With no argument, it
uses the newest clean backup under CURSOR_WORKBENCH_PATCH_BACKUP_ROOT. Passing
an explicit backup path restores that exact file.

Environment:
  CURSOR_WORKBENCH_PATCH_BACKUP_ROOT
    Directory containing cursor-app-* backup folders.
USAGE
}

# Print an error message and stop immediately with failure.
die() {
  echo "error: $*" >&2
  exit 1
}

# Print the newest clean backup path under BACKUP_ROOT.
latest_clean_backup() {
  local backup
  while IFS= read -r backup; do
    if cursor_patch_is_clean_backup "$backup"; then
      printf '%s\n' "$backup"
      return 0
    fi
  done < <(find "$BACKUP_ROOT" -path '*/cursor-app-*/workbench.html' -type f 2>/dev/null | sort -r)

  return 1
}

# Coordinate backup selection, workbench restore, and output.
main() {
  if [[ $# -gt 1 ]]; then
    print_script_usage
    exit 2
  fi

  local workbench_html backup_path
  workbench_html=$(cursor_patch_find_primary_workbench_html) ||
    die "Cursor workbench.html not found in known locations"

  if [[ $# -eq 1 ]]; then
    backup_path="$1"
  else
    backup_path=$(latest_clean_backup) ||
      die "no clean backups found under $BACKUP_ROOT"
  fi

  [[ -f "$backup_path" ]] || die "backup not found: $backup_path"

  cp -p "$backup_path" "$workbench_html"

  if ! grep -qF "$CURSOR_PATCH_JS_OUTPUT_NAME" "$workbench_html"; then
    rm -f "$(cursor_patch_managed_js_path "$workbench_html")"
  fi

  cat <<EOF
OK: Cursor workbench restored from backup.

Workbench:
  $workbench_html

Restored backup:
  $backup_path

Next:
  Run "Developer: Reload Window" in Cursor, or restart Cursor.
EOF
}

main "$@"
